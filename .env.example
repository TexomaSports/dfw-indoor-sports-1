# ================================
# DFW Indoor Sports - Environment Variables
# ================================

# Site Configuration (Required)
NEXT_PUBLIC_SITE_URL=https://dfwindoorsports.com

# Contact Form & Newsletter (Required for email functionality)
RESEND_API_KEY=re_xxxxxxxxxx
CONTACT_EMAIL=info@dfwindoorsports.com

# Google Search Console (Optional)
# GOOGLE_SITE_VERIFICATION=your-verification-code

# Analytics (Optional)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Mailchimp Newsletter (Optional - alternative to Resend)
# MAILCHIMP_API_KEY=xxxx
# MAILCHIMP_LIST_ID=xxxx
